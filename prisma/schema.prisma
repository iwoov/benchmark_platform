generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum PlatformRole {
  SUPER_ADMIN
  PLATFORM_ADMIN
  USER
}

enum ProjectStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ProjectMemberRole {
  AUTHOR
  REVIEWER
}

enum DataSourceType {
  DINGTALK_BITABLE
  JSON_UPLOAD
  EXCEL_UPLOAD
}

enum DataSourceStatus {
  ACTIVE
  INACTIVE
}

enum QuestionStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum ReviewDecision {
  PASS
  REJECT
}

enum AiProtocol {
  OPENAI_COMPATIBLE
  GEMINI_COMPATIBLE
  ANTHROPIC_COMPATIBLE
}

enum AiReasoningLevel {
  DISABLED
  LOW
  MEDIUM
  HIGH
}

enum RunStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

enum BatchRunStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  CANCEL_REQUESTED
  CANCELLED
}

enum BatchRunItemStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  SKIPPED
  CANCELLED
}

enum SyncDirection {
  PULL
  PUSH
}

enum SyncStatus {
  SUCCESS
  FAILED
}

model User {
  id                        String                             @id @default(cuid())
  username                  String?                            @unique
  email                     String?                            @unique
  name                      String
  passwordHash              String
  avatar                    String?
  mobile                    String?
  dingtalkUserId            String?                            @unique
  status                    UserStatus                         @default(ACTIVE)
  platformRole              PlatformRole                       @default(USER)
  createdProjects           Project[]                          @relation("ProjectCreator")
  memberships               ProjectMember[]
  reviews                   Review[]
  aiReviewRuns              AiReviewRun[]                      @relation("AiReviewRunTrigger")
  aiReviewStrategies        AiReviewStrategy[]                 @relation("AiReviewStrategyCreator")
  aiReviewStrategyRuns      AiReviewStrategyRun[]              @relation("AiReviewStrategyRunTrigger")
  aiReviewStrategyBatchRuns AiReviewStrategyBatchRun[]         @relation("AiReviewStrategyBatchRunCreator")
  dingtalkAccounts          DingtalkAccount[]
  reviewFieldPreferences    UserProjectReviewFieldPreference[]
  createdAt                 DateTime                           @default(now())
  updatedAt                 DateTime                           @updatedAt
}

model Project {
  id                        String                             @id @default(cuid())
  name                      String
  code                      String                             @unique
  description               String?
  fieldLabelMap             Json?
  status                    ProjectStatus                      @default(ACTIVE)
  createdById               String
  createdBy                 User                               @relation("ProjectCreator", fields: [createdById], references: [id])
  members                   ProjectMember[]
  datasources               ProjectDataSource[]
  questions                 Question[]
  reviews                   Review[]
  aiReviewRuns              AiReviewRun[]
  aiReviewStrategyBatchRuns AiReviewStrategyBatchRun[]
  syncLogs                  SyncLog[]
  reviewFieldPreferences    UserProjectReviewFieldPreference[]
  createdAt                 DateTime                           @default(now())
  updatedAt                 DateTime                           @updatedAt
}

model UserProjectReviewFieldPreference {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  config    Json
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, projectId])
}

model ProjectMember {
  id        String            @id @default(cuid())
  projectId String
  userId    String
  role      ProjectMemberRole
  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime          @default(now())

  @@unique([projectId, userId])
}

model ProjectDataSource {
  id              String           @id @default(cuid())
  projectId       String
  name            String
  type            DataSourceType   @default(DINGTALK_BITABLE)
  externalAppId   String?
  externalTableId String?
  externalViewId  String?
  fieldMapping    Json?
  syncConfig      Json?
  status          DataSourceStatus @default(ACTIVE)
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  questions       Question[]
  reviews         Review[]
  aiReviewRuns    AiReviewRun[]
  syncLogs        SyncLog[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Question {
  id                            String                         @id @default(cuid())
  projectId                     String
  datasourceId                  String
  externalRecordId              String
  title                         String
  content                       String
  answer                        String?
  analysis                      String?
  questionType                  String?
  difficulty                    String?
  status                        QuestionStatus                 @default(DRAFT)
  metadata                      Json?
  sourceUpdatedAt               DateTime?
  lastSyncedAt                  DateTime?
  project                       Project                        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  datasource                    ProjectDataSource              @relation(fields: [datasourceId], references: [id], onDelete: Cascade)
  aiReviewStrategyRuns          AiReviewStrategyRun[]
  aiReviewStrategyBatchRunItems AiReviewStrategyBatchRunItem[]
  fieldTranslations             QuestionFieldTranslation[]
  createdAt                     DateTime                       @default(now())
  updatedAt                     DateTime                       @updatedAt

  @@unique([datasourceId, externalRecordId])
  @@index([projectId, status])
  @@index([projectId, datasourceId])
}

model Review {
  id               String            @id @default(cuid())
  projectId        String
  datasourceId     String
  externalRecordId String
  reviewerId       String
  decision         ReviewDecision
  comment          String
  suggestions      Json?
  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  datasource       ProjectDataSource @relation(fields: [datasourceId], references: [id], onDelete: Cascade)
  reviewer         User              @relation(fields: [reviewerId], references: [id], onDelete: Cascade)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([projectId, datasourceId, externalRecordId])
}

model AiReviewRun {
  id               String            @id @default(cuid())
  projectId        String
  datasourceId     String
  externalRecordId String
  triggeredById    String
  modelProvider    String
  modelName        String
  promptVersion    String
  requestPayload   Json
  responsePayload  Json?
  parsedResult     Json?
  status           RunStatus         @default(PENDING)
  errorMessage     String?
  startedAt        DateTime?
  finishedAt       DateTime?
  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  datasource       ProjectDataSource @relation(fields: [datasourceId], references: [id], onDelete: Cascade)
  triggeredBy      User              @relation("AiReviewRunTrigger", fields: [triggeredById], references: [id], onDelete: Cascade)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([projectId, datasourceId, externalRecordId])
}

model AiProvider {
  id              String                     @id @default(cuid())
  code            String                     @unique
  name            String
  apiKey          String?
  note            String?
  endpoints       AiProviderEndpoint[]
  supportedModels AiProviderSupportedModel[]
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
}

model AiProviderEndpoint {
  id         String                    @id @default(cuid())
  providerId String
  code       String                    @unique
  label      String
  protocol   AiProtocol
  baseUrl    String
  sortOrder  Int                       @default(0)
  provider   AiProvider                @relation(fields: [providerId], references: [id], onDelete: Cascade)
  models     AiProviderEndpointModel[]
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt

  @@unique([providerId, protocol])
  @@index([providerId, sortOrder])
}

model AiModel {
  id                 String                    @id @default(cuid())
  code               String                    @unique
  protocol           AiProtocol
  streamDefault      Boolean                   @default(true)
  reasoningLevel     AiReasoningLevel          @default(DISABLED)
  maxTokensDefault   Int?
  temperatureDefault Float?
  maxRetries         Int                       @default(1)
  allowFallback      Boolean                   @default(true)
  label              String?
  note               String?
  endpoints          AiProviderEndpointModel[]
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
}

model AiProviderSupportedModel {
  id          String     @id @default(cuid())
  providerId  String
  name        String
  protocol    AiProtocol
  companyName String?
  sortOrder   Int        @default(0)
  provider    AiProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([providerId, name, protocol])
  @@index([providerId, sortOrder])
  @@index([providerId, protocol, sortOrder])
  @@index([companyName])
}

model AiProviderEndpointModel {
  endpointId String
  modelId    String
  priority   Int                @default(1)
  enabled    Boolean            @default(true)
  timeoutMs  Int                @default(15000)
  endpoint   AiProviderEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  model      AiModel            @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@id([endpointId, modelId])
  @@unique([modelId, priority])
  @@index([modelId])
  @@index([modelId, enabled, priority])
}

model AiReviewStrategy {
  id            String                     @id @default(cuid())
  code          String                     @unique
  name          String
  description   String?
  enabled       Boolean                    @default(true)
  projectIds    Json?
  datasourceIds Json?
  questionTypes Json?
  definition    Json
  createdById   String
  createdBy     User                       @relation("AiReviewStrategyCreator", fields: [createdById], references: [id], onDelete: Restrict)
  runs          AiReviewStrategyRun[]
  batchRuns     AiReviewStrategyBatchRun[]
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt

  @@index([enabled, createdAt])
}

model AiReviewStrategyRun {
  id              String           @id @default(cuid())
  strategyId      String
  questionId      String
  triggeredById   String
  status          RunStatus        @default(PENDING)
  requestPayload  Json
  responsePayload Json?
  parsedResult    Json?
  errorMessage    String?
  startedAt       DateTime?
  finishedAt      DateTime?
  strategy        AiReviewStrategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  question        Question         @relation(fields: [questionId], references: [id], onDelete: Cascade)
  triggeredBy     User             @relation("AiReviewStrategyRunTrigger", fields: [triggeredById], references: [id], onDelete: Cascade)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([questionId, createdAt])
  @@index([strategyId, createdAt])
}

model AiReviewStrategyBatchRun {
  id              String                         @id @default(cuid())
  strategyId      String
  projectId       String
  createdById     String
  status          BatchRunStatus                 @default(PENDING)
  concurrency     Int                            @default(1)
  totalCount      Int                            @default(0)
  pendingCount    Int                            @default(0)
  runningCount    Int                            @default(0)
  successCount    Int                            @default(0)
  failedCount     Int                            @default(0)
  skippedCount    Int                            @default(0)
  requestPayload  Json
  summaryPayload  Json?
  errorMessage    String?
  workerId        String?
  startedAt       DateTime?
  finishedAt      DateTime?
  lastHeartbeatAt DateTime?
  strategy        AiReviewStrategy               @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  project         Project                        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy       User                           @relation("AiReviewStrategyBatchRunCreator", fields: [createdById], references: [id], onDelete: Cascade)
  items           AiReviewStrategyBatchRunItem[]
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt

  @@index([projectId, createdAt])
  @@index([status, createdAt])
  @@index([createdById, createdAt])
  @@index([workerId, status])
}

model AiReviewStrategyBatchRunItem {
  id            String                   @id @default(cuid())
  batchRunId    String
  questionId    String
  sequence      Int
  status        BatchRunItemStatus       @default(PENDING)
  attemptCount  Int                      @default(0)
  runId         String?
  errorMessage  String?
  resultPayload Json?
  startedAt     DateTime?
  finishedAt    DateTime?
  batchRun      AiReviewStrategyBatchRun @relation(fields: [batchRunId], references: [id], onDelete: Cascade)
  question      Question                 @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  @@unique([batchRunId, questionId])
  @@unique([batchRunId, sequence])
  @@index([batchRunId, status, sequence])
  @@index([questionId, createdAt])
}

model SyncLog {
  id               String            @id @default(cuid())
  projectId        String
  datasourceId     String
  externalRecordId String?
  direction        SyncDirection
  action           String
  requestPayload   Json?
  responsePayload  Json?
  status           SyncStatus
  errorMessage     String?
  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  datasource       ProjectDataSource @relation(fields: [datasourceId], references: [id], onDelete: Cascade)
  createdAt        DateTime          @default(now())

  @@index([projectId, datasourceId, externalRecordId])
}

model QuestionFieldTranslation {
  id             String   @id @default(cuid())
  questionId     String
  fieldKey       String
  translatedText String
  sourceLanguage String?
  modelCode      String?
  question       Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([questionId, fieldKey])
  @@index([questionId])
}

model DingtalkAccount {
  id             String    @id @default(cuid())
  userId         String
  unionId        String?   @unique
  dingtalkUserId String?   @unique
  accessToken    String?
  refreshToken   String?
  tokenExpiredAt DateTime?
  scope          String?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model AiChatConfig {
  id           String   @id @default(cuid())
  name         String
  modelCode    String
  modelCodes   Json?
  systemPrompt String?  @db.Text
  presetFields Json?
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
