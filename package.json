{
    "name": "evalcheck",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev -p 3001",
        "dev:web": "next dev -p 3001",
        "dev:worker": "tsx scripts/ai-review-batch-worker.ts",
        "dev:all": "concurrently -k -n web,worker -c blue,green \"pnpm dev:web\" \"pnpm dev:worker\"",
        "build": "next build",
        "start": "next start",
        "start:web": "next start",
        "start:all": "concurrently -k -n web,worker -c blue,green \"pnpm start:web\" \"pnpm worker:ai-review-batch\"",
        "lint": "eslint .",
        "typecheck": "tsc --noEmit",
        "check": "pnpm prisma:generate && pnpm typecheck && pnpm lint",
        "db:push": "prisma db push",
        "postinstall": "prisma generate",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "prisma:studio": "prisma studio",
        "seed": "tsx prisma/seed.ts",
        "db:setup": "prisma migrate dev && pnpm seed",
        "worker:ai-review-batch": "tsx scripts/ai-review-batch-worker.ts"
    },
    "dependencies": {
        "@ant-design/nextjs-registry": "^1.3.0",
        "@ant-design/v5-patch-for-react-19": "^1.0.3",
        "@prisma/client": "^6.7.0",
        "antd": "^5.27.6",
        "bcryptjs": "^3.0.2",
        "clsx": "^2.1.1",
        "jszip": "^3.10.1",
        "lucide-react": "^0.542.0",
        "next": "^16.0.0",
        "next-auth": "^5.0.0-beta.29",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "server-only": "^0.0.1",
        "xlsx": "^0.18.5",
        "zod": "^4.1.11"
    },
    "devDependencies": {
        "@types/node": "^24.5.2",
        "@types/react": "^19.1.13",
        "@types/react-dom": "^19.1.9",
        "concurrently": "^9.2.1",
        "eslint": "^9.35.0",
        "eslint-config-next": "^16.0.0",
        "prisma": "^6.7.0",
        "tsx": "^4.20.6",
        "typescript": "^5.9.2"
    }
}
